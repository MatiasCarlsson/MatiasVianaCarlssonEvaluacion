# ─────────────────────────────────────────────────────────────────
# Base de datos — Supabase (PostgreSQL administrado)
#
# NOTA PARA EL EVALUADOR: Este proyecto usa Supabase como base de
# datos. Las credenciales ya están configuradas para que la app
# funcione sin pasos adicionales. No es necesario instalar PostgreSQL
# localmente ni crear ninguna base de datos.
# ─────────────────────────────────────────────────────────────────

# Cadena de conexión principal (a través del connection pooler de Supabase)
DATABASE_URL="TU_SUPABASE_DATABASE_URL"

# URL directa (conexión sin pooler, requerida por Prisma para migraciones)
DIRECT_URL="TU_SUPABASE_DIRECT_URL"
