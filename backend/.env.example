# Base de datos (PostgreSQL) 
# Cadena de conexión principal de Prisma.
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
DATABASE_URL="postgresql://postgres:password@localhost:5432/notes_db"

# URL directa (necesaria si usás un pooler como PgBouncer o Supabase).
# En desarrollo local podés poner la misma que DATABASE_URL.
DIRECT_URL="postgresql://postgres:password@localhost:5432/notes_db"
